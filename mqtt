@login_required
def setup_2fa_qr():
    global _qr_token_used
    with _qr_token_lock:
        if _qr_token_used:
            return (
                "<h2 style='font-family:monospace'>QR code déjà téléchargé.</h2>",
                410,
            )
        _qr_token_used = True

    png = _generate_qr_png()
    buf = io.BytesIO(png)
    buf.seek(0)
    return send_file(
        buf,
        mimetype="image/png",
        as_attachment=True,
        download_name="carhorizon_2fa_qr.png",
    )

