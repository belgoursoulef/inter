import base64
import json
import os
import threading
import time

import paho.mqtt.client as mqtt

MQTT_BROKER   = os.environ.get("MQTT_BROKER", "10.0.0.11")
MQTT_PORT     = int(os.environ.get("MQTT_PORT", "1883"))
MQTT_USERNAME = os.environ.get("MQTT_USERNAME", "")
MQTT_PASSWORD = os.environ.get("MQTT_PASSWORD", "")

# Topic ciblé directement sur Societe2
MQTT_TOPIC = "application/324a4234-8af8-4c93-bf7c-407de4a9e4a5/device/a840412051896d52/event/up"
SOCIETE2_EUI = "a840412051896d52"

latest_data = {}
data_lock   = threading.Lock()


def decode_la66_payload(b64_data):
    """
    Décode le payload binaire LA66 (fPort 2).
    Format : 4 bytes — int16 BE signed / 100
      bytes[0:2] → température (°C)
      bytes[2:4] → humidité (%)
    """
    try:
        raw = base64.b64decode(b64_data)
        if len(raw) < 4:
            return None, None
        temp     = int.from_bytes(raw[0:2], 'big', signed=True) / 100
        humidity = int.from_bytes(raw[2:4], 'big', signed=True) / 100
        return temp, humidity
    except Exception as e:
        print(f"[decode] Erreur décodage payload: {e}")
        return None, None


def extract_device_name(payload):
    return payload.get("deviceInfo", {}).get("deviceName", "inconnu")


def on_connect(client, userdata, flags, reason_code, properties=None):
    if reason_code != 0:
        print(f"[MQTT] Connexion refusée, code: {reason_code}")
        return
    print(f"[MQTT] Connecté à {MQTT_BROKER}:{MQTT_PORT}")
    client.subscribe(MQTT_TOPIC)
    print(f"[MQTT] Abonné: {MQTT_TOPIC}")


def on_disconnect(client, userdata, reason_code, properties=None):
    print(f"[MQTT] Déconnecté (code {reason_code}), reconnexion en cours...")


def on_message(client, userdata, msg):
    try:
        payload = json.loads(msg.payload.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError):
        print(f"[MQTT] Message ignoré (JSON invalide) sur {msg.topic}")
        return

    # Vérification double sécurité sur le devEui
    dev_eui = payload.get("deviceInfo", {}).get("devEui", "").lower()
    if dev_eui != SOCIETE2_EUI:
        return

    b64_data = payload.get("data")
    if not b64_data:
        print("[MQTT] Pas de champ 'data' dans le payload")
        return

    temp, humidity = decode_la66_payload(b64_data)
    if temp is None:
        print(f"[MQTT] Décodage échoué pour data={b64_data}")
        return

    record = {
        "device_id":   dev_eui,
        "device_name": extract_device_name(payload),
        "temperature": temp,
        "humidity":    humidity,
        "timestamp":   payload.get("time") or payload.get("received_at"),
        "rssi":        (payload.get("rxInfo") or [{}])[0].get("rssi"),
        "snr":         (payload.get("rxInfo") or [{}])[0].get("snr"),
        "fCnt":        payload.get("fCnt"),
        "topic":       msg.topic,
    }

    print(f"[MQTT] Societe2 → {temp}°C  {humidity}% HR  RSSI={record['rssi']} dBm")

    with data_lock:
        latest_data[dev_eui] = record


def start_mqtt_listener():
    while True:
        try:
            client = mqtt.Client(callback_api_version=mqtt.CallbackAPIVersion.VERSION2)
            if MQTT_USERNAME:
                client.username_pw_set(MQTT_USERNAME, MQTT_PASSWORD)

            client.on_connect    = on_connect
            client.on_disconnect = on_disconnect
            client.on_message    = on_message

            print(f"[MQTT] Connexion à {MQTT_BROKER}:{MQTT_PORT}...")
            client.connect(MQTT_BROKER, MQTT_PORT, keepalive=60)
            client.loop_forever()
        except Exception as e:
            print(f"[MQTT] Erreur: {e} — nouvelle tentative dans 10s...")
            time.sleep(10)
